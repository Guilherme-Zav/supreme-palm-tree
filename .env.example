# ─────────────────────────────────────────────────────────────
# Minha Agência IA — variáveis de ambiente
# ─────────────────────────────────────────────────────────────

# Sua chave da API da Anthropic.
# Pegue em https://console.anthropic.com/  → Settings → API Keys
# e garanta que sua conta tem créditos (Settings → Billing).
# IMPORTANTE: coloque a chave em um arquivo .env.local (que NÃO vai pro git),
# não neste arquivo de exemplo.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (Opcional) Modelo padrão usado para gerar a copy.
# Deixe em branco para usar o padrão da aplicação (claude-opus-4-8).
# Alternativa mais rápida/barata: claude-sonnet-4-6
# ANTHROPIC_MODEL=claude-opus-4-8

# Banco de dados local (SQLite). Já vem configurado no arquivo .env.
# DATABASE_URL="file:./dev.db"
